# Server
PORT=8080
ENVIRONMENT=development

# Database — Replit injects PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE at runtime
# Leave these blank so the config falls back to the PG* secrets
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL_MODE=disable
DB_MAX_CONNS=25

# Redis — overridden by Replit secrets at runtime
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=
REDIS_TLS=false

# JWT — overridden by Replit secrets at runtime
JWT_SECRET=dev-secret-change-in-production

# Settlement Contracts
SETTLEMENT_CONTRACT_BSC=0x4896ebe3EE1436a58c690A8021301A6bFD6BD4E7
SETTLEMENT_CONTRACT_BASE=0x723da0ef5eea8370015465e9Cf2513D7e48e1b61

# RPC URLs — overridden by Replit secrets at runtime
INFURA_URL=https://bsc-dataseed.nariox.org/
ALCHEMY_URL=

# Executor — overridden by Replit secrets at runtime
EXECUTOR_ENABLED=true
EXECUTOR_PRIVATE_KEY=
EXECUTOR_RPC_URL=https://bsc-dataseed.defibit.io/
EXECUTOR_RPC_URL_BASE=

EXECUTOR_INTERVAL_MS=5000
CHAIN_ID=56
CHAIN_ID_BASE=8453
SETTLEMENT_ADDRESS=0x4896ebe3EE1436a58c690A8021301A6bFD6BD4E7
SETTLEMENT_ADDRESS_BASE=0x723da0ef5eea8370015465e9Cf2513D7e48e1b61
