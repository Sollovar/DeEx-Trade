# ── Non-secret defaults only ──────────────────────────────────────────────────
# Sensitive values (DB_HOST, DB_USER, DB_PASSWORD, REDIS_URL, JWT_SECRET, etc.)
# MUST be stored as Replit Secrets — never put them here.
# godotenv.Load() does NOT override env vars already set by Replit Secrets.

# Server
PORT=8080
ENVIRONMENT=development

# Database defaults (overridden by Replit Secrets at runtime)
DB_NAME=postgres
DB_SSL_MODE=require
DB_MAX_CONNS=25

# Executor (disabled by default; enable via Replit Secret)
EXECUTOR_ENABLED=false
EXECUTOR_INTERVAL_MS=5000
CHAIN_ID=56
CHAIN_ID_BASE=8453
